{
  "name": "towel",
  "version": "1.0.0",
  "description": "Desktop application for Towel.",
  "author": {
    "name": "Rajiv Patki",
    "email": "rajivpatki@users.noreply.github.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:frontend && npm run build:backend && electron-builder",
    "build:frontend": "cd frontend && npm install && VITE_API_BASE_URL=http://localhost:8000 npm run build",
    "build:backend": "cd backend_go && go build -o ../backend-server .",
    "build:backend:win": "cd backend_go && set CGO_ENABLED=1 && go build -o ../backend-server.exe .",
    "build:backend:unix": "cd backend_go && CGO_ENABLED=1 go build -o ../backend-server .",
    "dist": "electron-builder",
    "dist:all": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.towel.app",
    "productName": "Towel",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "frontend/dist/**/*",
      "!backend_go/**/*",
      "!frontend/node_modules/**/*",
      "!frontend/src/**/*",
      "!frontend/vite.config.js"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "extraResources": [
        {
          "from": "backend-server",
          "to": "backend-server"
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "extraResources": [
        {
          "from": "backend-server.exe",
          "to": "backend-server.exe"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "extraResources": [
        {
          "from": "backend-server",
          "to": "backend-server"
        }
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
