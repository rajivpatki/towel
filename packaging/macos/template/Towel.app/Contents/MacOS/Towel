#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
STARTER_PATH="$SCRIPT_DIR/../Resources/start_towel.command"

exec /usr/bin/osascript - "$STARTER_PATH" <<'APPLESCRIPT'
on run argv
  set commandPath to POSIX path of (item 1 of argv as alias)
  tell application "Terminal"
    activate
    do script quoted form of commandPath
  end tell
end run
APPLESCRIPT
